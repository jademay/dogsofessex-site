rules_version = '2';

// Security rules for the community tips collection.
// Paste these into: Firebase console → Firestore Database → Rules → Publish.
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'jademay01@gmail.com';
    }

    match /tips/{tipId} {
      // Anyone may submit a tip, but only as a "pending" one with sane fields.
      allow create: if request.resource.data.status == 'pending'
        && request.resource.data.walkId is string
        && request.resource.data.walkId.size() > 0
        && request.resource.data.walkId.size() < 100
        && request.resource.data.tip is string
        && request.resource.data.tip.size() > 0
        && request.resource.data.tip.size() <= 800;

      // Anyone can read approved tips; the admin can read everything (pending too).
      allow read: if resource.data.status == 'approved' || isAdmin();

      // Only the admin can approve / reject / delete.
      allow update, delete: if isAdmin();
    }
  }
}
